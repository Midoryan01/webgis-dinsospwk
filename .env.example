# ─── Database ─────────────────────────────────────────────────────────────────
# Format: mysql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL="mysql://root:password@localhost:3306/webgis_pkh"

# ─── JWT Authentication ────────────────────────────────────────────────────────
# WAJIB di production! Generate dengan:
#   node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=qbuwhuqheih012heh102he01h0

# ─── Credentials Admin (NIP/Username) ─────────────────────────────────────────
ADMIN_NIP=admin
OPERATOR_NIP=199001012020121001

# ─── Password Hashes (WAJIB di production) ─────────────────────────────────────
# Generate dengan: node scripts/hash-password.js <password>
#
# Contoh output (JANGAN gunakan hash ini di production — generate sendiri!):
#   ADMIN_PASSWORD_HASH=$2a$10$N9qo8uLOickgx2ZMRZoMyeIjZAgcfl7p92ldGxad68LJZdL17lh
#   OPERATOR_PASSWORD_HASH=$2a$10$xH.nR2yDz3sQJVYnuWjOB.8/UQOKhj8JVZMtKxhRLw9Yq2MJ84f2
#
ADMIN_PASSWORD_HASH=
OPERATOR_PASSWORD_HASH=

# ─── Development Only (hapus atau biarkan kosong di production) ───────────────
# Ini hanya digunakan jika PASSWORD_HASH di atas kosong DAN NODE_ENV=development
ADMIN_DEV_PASS=admin123
OPERATOR_DEV_PASS=dinsos2024

# ─── App Config ──────────────────────────────────────────────────────────────
# Set ke "false" di production untuk menyembunyikan info demo
NEXT_PUBLIC_SHOW_DEMO_INFO=true
